# Mend MCP Server Environment Configuration
# Copy this file to .env and fill in your values

# Optional: Mend API key for advanced features
# MEND_API_KEY=your-api-key-here

# Maven Central cache TTL in seconds (default: 3600 = 1 hour)
MAVEN_CENTRAL_CACHE_TTL=3600

# Log level: debug, info, warn, error
LOG_LEVEL=info
