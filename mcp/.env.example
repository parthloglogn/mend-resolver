# Mend MCP Server Environment Configuration
# Copy this file to .env and fill in your values

# Optional: Mend API key for advanced features
# MEND_API_KEY=your-api-key-here

# Optional: Custom Mend API URL
# MEND_API_URL=https://api.mend.io/api/v1.4

# Maven Central cache TTL in seconds (default: 3600 = 1 hour)
MAVEN_CENTRAL_CACHE_TTL=3600

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Hard constraints (enforced by the server)
JDK_VERSION=17
TARGET_SPRING_BOOT=4.x
TARGET_SPRING_FRAMEWORK=7.x
MAVEN_VERSION=3.9.x
