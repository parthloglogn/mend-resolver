{
  "mcpServers": {
    "mend-mcp-server": {
      "name": "Mend MCP Server",
      "description": "Essential MCP server: Maven Central lookups, Mend report parsing, dependency conflict checking",
      "type": "local",
      "transport": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/mcp/src/server.js"
      ],
      "env": {
        "MEND_API_KEY": "${env:MEND_API_KEY}",
        "MAVEN_CENTRAL_CACHE_TTL": "3600",
        "LOG_LEVEL": "info"
      },
      "tools": [
        "maven-central-lookup",
        "mend-parse-report",
        "mend-check-conflicts"
      ]
    }
  }
}
