{
  "mcpServers": {
    "mend-mcp-server": {
      "name": "Mend MCP Server",
      "description": "MCP server for Mend vulnerability resolution, Maven Central lookups, and dependency conflict checking",
      "type": "local",
      "transport": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/mcp/src/server.js"
      ],
      "env": {
        "MEND_API_KEY": "${env:MEND_API_KEY}",
        "MAVEN_CENTRAL_CACHE_TTL": "3600",
        "LOG_LEVEL": "info"
      },
      "tools": [
        "maven-central-lookup",
        "mend-check-conflicts",
        "mend-validate-version",
        "mend-parse-report",
        "mend-get-cve-details"
      ],
      "initializationOptions": {
        "jdkVersion": 17,
        "targetSpringBoot": "4.x",
        "targetSpringFramework": "7.x",
        "mavenVersion": "3.9.x"
      }
    }
  }
}
